# VisionTriage Label Mapping Protocol

# ── ETDRS 5-Class ───────────────────────────

# Grade 0: No DR          → Low   (annual recall)
# Grade 1: Mild NPDR      → Low   (annual recall)
# Grade 2: Moderate NPDR  → Medium (4-8 week review)
# Grade 3: Severe NPDR    → High  (urgent, within 1 week)
# Grade 4: PDR            → High  (same-day or within 1 week)

idrid_etdrs_mapping:
  0: 0    # No DR           → Low
  1: 0    # Mild NPDR       → Low
  2: 1    # Moderate NPDR   → Medium
  3: 2    # Severe NPDR     → High
  4: 2    # PDR             → High

# ── Binary ───────────────────────────────────

# DR absent  → Low  (no pathology detected)
# DR present → High (conservative: assume worst case)
# Medium tier intentionally excluded — binary label cannot
# distinguish moderate from severe DR

dodr_binary_mapping:
  0: 0    # DR absent  → Low
  1: 2    # DR present → High

# ── Urgency Tier ──────────────────────────────────────────
urgency_tiers:
  low:
    label: 0
    name: "LOW"
    clinical_action: "Annual recall"
    timeframe_days: 365
    etdrs_grades: [0, 1]
    clinical_basis: "NHS DESP R0-R1, AAO PPP No DR / Mild NPDR"

  medium:
    label: 1
    name: "MEDIUM"
    clinical_action: "Specialist review"
    timeframe_days: 28
    etdrs_grades: [2]
    clinical_basis: "NHS DESP R2, AAO PPP Moderate NPDR"

  high:
    label: 2
    name: "HIGH"
    clinical_action: "Urgent referral"
    timeframe_days: 7
    etdrs_grades: [3, 4]
    clinical_basis: "NHS DESP R3, AAO PPP Severe NPDR / PDR"

# ── Class Weights ─────────────────────────────────────────────────────
idrid_only_weights:
  low: 1.00
  medium: 1.87
  high: 2.84

multisource_weights:
  low: 1.00
  medium: 13.09
  high: 1.12