# VisionTriage Configuration
# Copy to config.yaml and update paths for your environment

# ── Dataset Configuration ─────────────────────────────────────────────
dataset:
  name: "IDRiD"

  # Raw IDRiD dataset paths (update these)
  raw_path: "your_path/DiseaseGrading"
  processed_path: "your_path/data/processed"
  splits_path: "your_path/data/splits"

  # IDRiD CSV files
  train_csv: "your_path/IDRiD_Disease_Grading_Training_Labels.csv"
  test_csv: "your_path/Groundtruths/IDRiD_Disease_Grading_Testing_Labels.csv"

  # IDRiD image directories
  train_image_dir: "your_path/Original_Images/a. Training Set"
  test_image_dir: "your_path/Original_Images/b. Testing Set"

  image_format: "jpg"
  diagnosis_column: "Retinopathy grade"

  # Image dimensions
  resize_to: 512
  crop_to: 480

  num_classes: 3
  random_seed: 42

# ── Model Configurations ──────────────────────────────────────────────
models:

  # M1
  baseline_cnn:
    name: "M1-ResNet50-Monocular"
    backbone: "resnet50"
    pretrained: true
    input_channels: 3
    output_features: 2048
    dropout: 0.5

  # M2
  baseline_concat:
    name: "M2-ResNet50-LateConcat"
    backbone: "resnet50"
    pretrained: true
    fusion_type: "concat"
    fc_hidden_dim: 1024
    dropout: 0.5

  # M3
  proposed_crossattn:
    name: "M3-ResNet50-CrossAttention"
    backbone: "resnet50"
    pretrained: true
    fusion_type: "cross_attention"
    num_heads: 8
    attn_dim: 256
    fc_hidden_dim: 512
    dropout: 0.5

# ── Training Configuration ────────────────────────────────────────────
training:
  batch_size: 32
  num_epochs: 50

  # AdamW optimizer
  optimizer: "adamw"
  learning_rate: 0.0001
  weight_decay: 0.00001

  # Cosine annealing scheduler
  scheduler: "cosine_annealing"
  t_max: 50
  eta_min: 0.0

  # Early stopping
  early_stopping:
    patience: 10
    monitor: "val_macro_f1"
    mode: "max"
    min_delta: 0.001

  class_weights: [1.00, 1.87, 2.84]

  # Dropout regularization
  dropout: 0.5

# ── Data Augmentation ─────────────────────────
augmentation:
  enabled: true

  horizontal_flip:
    enabled: true
    probability: 0.5

  rotation:
    enabled: true
    degrees: 30
    probability: 0.7

  color_jitter:
    enabled: true
    probability: 0.5
    brightness: 0.2
    contrast: 0.2
    saturation: 0.1
    hue: 0.0

  random_resized_crop:
    enabled: true
    size: 480
    scale_min: 0.8
    scale_max: 1.0

# ── Preprocessing ─────────────────────────────
preprocessing:
  clahe:
    clip_limit: 2.0
    tile_grid_size: 8

  normalization:
    mean: [0.485, 0.456, 0.406]
    std: [0.229, 0.224, 0.225] 

# ── Reproducibility ───────────────────────────────────────────────────
reproducibility:
  seeds: [42, 0, 123]
  deterministic: true

# ── GPU / Hardware ────────────────────────────────────────────────────
gpu:
  device: "cuda"                # "cpu" if no GPU
  num_workers: 4                # Adjust to CPU core count
  pin_memory: true

# ── Logging ───────────────────────────────────────────────────────────
logging:
  tensorboard_dir: "runs"
  checkpoint_dir: "checkpoints"
  metrics_dir: "results"
  log_interval: 10